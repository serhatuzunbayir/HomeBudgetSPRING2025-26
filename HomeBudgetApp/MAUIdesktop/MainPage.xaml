<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MAUIdesktop"
             x:Class="MAUIdesktop.MainPage"
             Title="My Budget">

    <Grid ColumnDefinitions="220,*">
        <Grid BackgroundColor="{StaticResource FinanceSidebar}"
              Padding="22"
              RowDefinitions="Auto,*,Auto">
            <VerticalStackLayout Spacing="8">
                <Label Text="HomeBudget"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}" />
                <Label Text="Personal finance workspace"
                       FontSize="12"
                       TextColor="{StaticResource FinanceSidebarText}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1"
                                 Margin="0,34,0,0"
                                 Spacing="12">
                <Button Text="Dashboard"
                        Style="{StaticResource SuccessButtonStyle}" />
                <Button Text="Family"
                        Clicked="OnFamilyClicked"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Text="Profile"
                        Clicked="OnProfileClicked"
                        Style="{StaticResource SecondaryButtonStyle}" />
            </VerticalStackLayout>

            <Button Grid.Row="2"
                    Text="Logout"
                    Clicked="OnLogoutClicked"
                    Style="{StaticResource DangerButtonStyle}" />
        </Grid>

        <ScrollView Grid.Column="1">
            <Grid Padding="28"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  RowSpacing="20">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="WelcomeLabel"
                               Style="{StaticResource PageTitleStyle}" />
                        <Label Text="Track spending, category limits, alerts, and family budget activity."
                               Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Add category"
                            Clicked="OnAddCategoryClicked"
                            VerticalOptions="Center" />
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="14">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Total Budget" Style="{StaticResource MutedLabelStyle}" />
                            <Label x:Name="TotalBudgetLabel" Style="{StaticResource MetricValueStyle}" />
                            <Label Text="Allocated across categories" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Total Spent" Style="{StaticResource MutedLabelStyle}" />
                            <Label x:Name="TotalSpentLabel" Style="{StaticResource MetricValueStyle}" TextColor="{StaticResource FinanceDanger}" />
                            <Label Text="All recorded expenses" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Remaining Budget" Style="{StaticResource MutedLabelStyle}" />
                            <Label x:Name="RemainingBudgetLabel" Style="{StaticResource MetricValueStyle}" TextColor="{StaticResource FinanceSuccess}" />
                            <Label Text="Available to spend" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="This Month" Style="{StaticResource MutedLabelStyle}" />
                            <Label x:Name="ThisMonthExpensesLabel" Style="{StaticResource MetricValueStyle}" />
                            <Label Text="Current month expenses" Style="{StaticResource MutedLabelStyle}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="2*,*"
                      ColumnSpacing="18">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Text="Category Budget Status" Style="{StaticResource SectionTitleStyle}" />
                            <Label Grid.Column="1"
                                   x:Name="CategoryCountLabel"
                                   Style="{StaticResource MutedLabelStyle}"
                                   VerticalTextAlignment="Center" />
                        </Grid>

                        <CollectionView x:Name="CategoryCollection"
                                        EmptyView="No categories yet. Add one to start tracking your expenses.">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="14" VerticalItemSpacing="14" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="local:CategoryCardViewModel">
                                    <Border Style="{StaticResource CardBorderStyle}">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                                    <Label Text="{Binding StatusDisplay}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="{Binding StatusColor}" />
                                                    <Label Text="{Binding AlertThresholdDisplay}"
                                                           Style="{StaticResource MutedLabelStyle}" />
                                                </VerticalStackLayout>

                                                <Button Grid.Column="1"
                                                        Text="Expense"
                                                        Clicked="OnAddExpenseClicked"
                                                        CommandParameter="{Binding .}" />
                                                <Button Grid.Column="2"
                                                        Text="Alert"
                                                        Clicked="OnSetAlertThresholdClicked"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource SecondaryButtonStyle}" />
                                                <Button Grid.Column="3"
                                                        Text="Delete"
                                                        Clicked="OnDeleteCategoryClicked"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource DangerButtonStyle}" />
                                            </Grid>

                                            <ProgressBar Grid.Row="1"
                                                         Progress="{Binding SpentProgress}"
                                                         Style="{StaticResource BudgetProgressStyle}" />

                                            <Grid Grid.Row="2" ColumnDefinitions="*,*,*">
                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="Spent" Style="{StaticResource MutedLabelStyle}" />
                                                    <Label Text="{Binding SpentDisplay}" FontAttributes="Bold" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="Remaining" Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="Center" />
                                                    <Label Text="{Binding RemainingDisplay}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="2" Spacing="2">
                                                    <Label Text="Average" Style="{StaticResource MutedLabelStyle}" HorizontalTextAlignment="End" />
                                                    <Label Text="{Binding MonthlyAverageDisplay}" FontAttributes="Bold" HorizontalTextAlignment="End" />
                                                </VerticalStackLayout>
                                            </Grid>

                                            <CollectionView Grid.Row="3"
                                                            ItemsSource="{Binding Expenses}"
                                                            EmptyView="No expenses added yet.">
                                                <CollectionView.ItemTemplate>
                                                    <DataTemplate x:DataType="local:ExpenseRowViewModel">
                                                        <Grid Padding="0,8"
                                                              ColumnDefinitions="*,Auto,Auto"
                                                              ColumnSpacing="10">
                                                            <VerticalStackLayout Spacing="1">
                                                                <Label Text="{Binding Description}" FontSize="14" />
                                                                <Label Text="{Binding Date}" Style="{StaticResource MutedLabelStyle}" />
                                                            </VerticalStackLayout>
                                                            <Label Grid.Column="1"
                                                                   Text="{Binding AmountDisplay}"
                                                                   VerticalTextAlignment="Center"
                                                                   FontAttributes="Bold"
                                                                   TextColor="{StaticResource FinanceDanger}" />
                                                            <Button Grid.Column="2"
                                                                    Text="Remove"
                                                                    Clicked="OnDeleteExpenseClicked"
                                                                    CommandParameter="{Binding .}"
                                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </CollectionView.ItemTemplate>
                                            </CollectionView>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="14">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Analytics" Style="{StaticResource SectionTitleStyle}" />
                                <Label Text="Monthly Average" Style="{StaticResource MutedLabelStyle}" />
                                <Label x:Name="MonthlyAverageLabel" Style="{StaticResource MetricValueStyle}" />
                                <Label Text="Real-time LINQ summaries are calculated from your stored expenses." Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Expense Summary by Category" Style="{StaticResource SectionTitleStyle}" />
                                <Label x:Name="ExpenseSummaryCaptionLabel"
                                       Style="{StaticResource MutedLabelStyle}" />
                                <CollectionView x:Name="ExpenseSummaryCollection"
                                                EmptyView="No categories yet. Add a category to see grouped spending insights.">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="local:CategoryExpenseSummaryViewModel">
                                            <Grid Padding="0,8"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <VerticalStackLayout Spacing="1">
                                                    <Label Text="{Binding CategoryName}" FontAttributes="Bold" />
                                                    <Label Text="{Binding ExpenseCountDisplay}" Style="{StaticResource MutedLabelStyle}" />
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="1"
                                                                     HorizontalOptions="End">
                                                    <Label Text="{Binding TotalSpentDisplay}"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="End" />
                                                    <Label Text="{Binding MonthlyAverageDisplay}"
                                                           Style="{StaticResource MutedLabelStyle}"
                                                           HorizontalTextAlignment="End" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Budget Alerts" Style="{StaticResource SectionTitleStyle}" />
                                <Label x:Name="BudgetAlertsLabel"
                                       Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="10">
                                <Label Text="Expense Explorer" Style="{StaticResource SectionTitleStyle}" />
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <Picker x:Name="ExpenseCategoryFilterPicker"
                                            Title="Filter by category"
                                            ItemDisplayBinding="{Binding Label}"
                                            SelectedIndexChanged="OnExpenseFilterChanged" />
                                    <Picker Grid.Column="1"
                                            x:Name="ExpenseSortPicker"
                                            Title="Sort expenses"
                                            ItemDisplayBinding="{Binding Label}"
                                            SelectedIndexChanged="OnExpenseFilterChanged" />
                                </Grid>
                                <Label x:Name="ExpenseExplorerCaptionLabel"
                                       Style="{StaticResource MutedLabelStyle}" />
                                <CollectionView x:Name="RecentExpensesCollection"
                                                EmptyView="No matching expenses yet.">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="local:ExpenseRowViewModel">
                                            <Grid Padding="0,8" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                <VerticalStackLayout Spacing="1">
                                                    <Label Text="{Binding Description}" FontAttributes="Bold" />
                                                    <Label Text="{Binding Date}" Style="{StaticResource MutedLabelStyle}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1"
                                                       Text="{Binding AmountDisplay}"
                                                       TextColor="{StaticResource FinanceDanger}"
                                                       FontAttributes="Bold"
                                                       VerticalTextAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Family Overview" Style="{StaticResource SectionTitleStyle}" />
                                <Label x:Name="FamilyOverviewLabel" Style="{StaticResource MutedLabelStyle}" />
                                <Button Text="Open family workspace"
                                        Clicked="OnFamilyClicked"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>

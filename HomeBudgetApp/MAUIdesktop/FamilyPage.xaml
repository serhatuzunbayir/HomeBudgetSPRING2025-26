<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MAUIdesktop"
             x:Class="MAUIdesktop.FamilyPage"
             Title="Family">

    <Grid ColumnDefinitions="220,*">
        <Grid BackgroundColor="{StaticResource FinanceSidebar}"
              Padding="22"
              RowDefinitions="Auto,*,Auto">
            <VerticalStackLayout Spacing="8">
                <Label Text="Family Budget"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource White}" />
                <Label Text="Shared spending control"
                       FontSize="12"
                       TextColor="{StaticResource FinanceSidebarText}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Row="1"
                                 Margin="0,34,0,0"
                                 Spacing="12">
                <Button Text="Personal page"
                        Clicked="OnPersonalClicked"
                        Style="{StaticResource SecondaryButtonStyle}" />
                <Button Text="Family"
                        Style="{StaticResource SuccessButtonStyle}" />
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Column="1">
            <Grid Padding="28"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="20">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Family Management" Style="{StaticResource PageTitleStyle}" />
                        <Label x:Name="FamilyStatusLabel" Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>

                    <Button Grid.Column="1"
                            Text="Personal page"
                            Clicked="OnPersonalClicked"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalOptions="Center" />
                </Grid>

                <Border x:Name="NoFamilyPanel"
                        Grid.Row="1"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid RowDefinitions="Auto,Auto"
                          RowSpacing="20">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="No family workspace is connected yet."
                                       Style="{StaticResource SectionTitleStyle}" />
                                <Label Text="Create a household budget or accept a pending invitation to join shared expense tracking."
                                       Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Create family"
                                    Clicked="OnCreateFamilyClicked"
                                    VerticalOptions="Center" />
                        </Grid>

                        <VerticalStackLayout Grid.Row="1" Spacing="10">
                            <Label Text="Pending Invitations" Style="{StaticResource SectionTitleStyle}" />
                            <CollectionView x:Name="InvitationsCollection"
                                            EmptyView="No pending invitations.">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="local:FamilyInvitationViewModel">
                                        <Grid Padding="0,10" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding FamilyName}" FontSize="16" FontAttributes="Bold" />
                                                <Label Text="{Binding InvitedByDisplay}" Style="{StaticResource MutedLabelStyle}" />
                                            </VerticalStackLayout>
                                            <Button Grid.Column="1"
                                                    Text="Accept"
                                                    Clicked="OnAcceptInvitationClicked"
                                                    CommandParameter="{Binding .}"
                                                    Style="{StaticResource SuccessButtonStyle}" />
                                            <Button Grid.Column="2"
                                                    Text="Decline"
                                                    Clicked="OnDeclineInvitationClicked"
                                                    CommandParameter="{Binding .}"
                                                    Style="{StaticResource SecondaryButtonStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Grid x:Name="FamilyWorkspace"
                      Grid.Row="1"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="18">
                    <Grid ColumnDefinitions="2*,*"
                          ColumnSpacing="18">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                <VerticalStackLayout Spacing="6">
                                    <Label x:Name="FamilyNameLabel"
                                           Style="{StaticResource SectionTitleStyle}" />
                                    <Label x:Name="FamilyRoleLabel"
                                           Style="{StaticResource MutedLabelStyle}" />
                                    <Label Text="Admins can invite registered users and remove members when needed."
                                           Style="{StaticResource MutedLabelStyle}" />
                                </VerticalStackLayout>
                                <Button x:Name="InviteButton"
                                        Grid.Column="1"
                                        Text="Invite member"
                                        Clicked="OnInviteMemberClicked"
                                        VerticalOptions="Center" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Access Status" Style="{StaticResource SectionTitleStyle}" />
                                <Label Text="Owner/Admin" Style="{StaticResource MutedLabelStyle}" />
                                <Label Text="Invite and remove members" FontSize="16" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1" Spacing="12">
                        <Label Text="Family Members" Style="{StaticResource SectionTitleStyle}" />
                        <CollectionView x:Name="MembersCollection"
                                        EmptyView="No members yet.">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="local:FamilyMemberViewModel">
                                    <Border Margin="0,0,0,10"
                                            Style="{StaticResource CardBorderStyle}">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                                <Label Text="{Binding Email}" Style="{StaticResource MutedLabelStyle}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Role}"
                                                   TextColor="{StaticResource FinanceSuccess}"
                                                   FontAttributes="Bold"
                                                   VerticalTextAlignment="Center" />
                                            <Button Grid.Column="2"
                                                    Text="Remove"
                                                    IsVisible="{Binding CanRemove}"
                                                    Clicked="OnRemoveMemberClicked"
                                                    CommandParameter="{Binding .}"
                                                    Style="{StaticResource DangerButtonStyle}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Grid>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>

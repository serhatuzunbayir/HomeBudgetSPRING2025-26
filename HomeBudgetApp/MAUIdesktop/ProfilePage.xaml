<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUIdesktop.ProfilePage"
             Title="Profile">

    <ScrollView>
        <Grid Padding="28"
              RowDefinitions="Auto,Auto"
              RowSpacing="20"
              MaximumWidthRequest="760"
              HorizontalOptions="Center">
            <VerticalStackLayout Spacing="4">
                <Label Text="Profile" Style="{StaticResource PageTitleStyle}" />
                <Label Text="Keep your account details current for budget and family access."
                       Style="{StaticResource MutedLabelStyle}" />
            </VerticalStackLayout>

            <Border Grid.Row="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="24">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Account Information" Style="{StaticResource SectionTitleStyle}" />

                    <Border Style="{StaticResource SoftPanelStyle}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Email" Style="{StaticResource MutedLabelStyle}" />
                            <Label x:Name="EmailLabel" FontSize="16" FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Name" Style="{StaticResource MutedLabelStyle}" />
                        <Entry x:Name="NameEntry" Placeholder="Enter your name" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="New password" Style="{StaticResource MutedLabelStyle}" />
                        <Entry x:Name="PasswordEntry" Placeholder="Leave unchanged to keep current password" IsPassword="True" />
                    </VerticalStackLayout>

                    <Label x:Name="MessageLabel" Style="{StaticResource MutedLabelStyle}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="Back" Clicked="OnBackClicked" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Grid.Column="1" Text="Save changes" Clicked="OnSaveClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>

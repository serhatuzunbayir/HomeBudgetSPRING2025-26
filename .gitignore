## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
wwwroot/lib/
node_modules/

# Visual Studio cache/options
.vs/

# VS Code (if you ever use it)
.vscode/

# Rider
.idea/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# NuGet
*.nupkg
packages/
!packages/build/
*.snupkg

# MAUI specific
*.apk
*.aab
*.app
*.ipa

# iOS / Android build folders
platforms/android/bin/
platforms/android/obj/
platforms/ios/bin/
platforms/ios/obj/

# MacCatalyst
platforms/maccatalyst/bin/
platforms/maccatalyst/obj/

# Windows
platforms/windows/bin/
platforms/windows/obj/

# Secrets
appsettings.Development.json
secrets.json

# Publish output
publish/


*.map